# AWS credentials and execution
AWS_REGION=us-east-1
AWS_PROFILE=default
AUTO_APPROVE=false

# App and Siteline runtime settings
APP_NAME=siteline-fastly-s3-processor
SITELINE_WEBSITE_KEY=siteline_secret_replace_with_real_key
SITELINE_ENDPOINT=https://api.siteline.ai/v1/intake/pageview
SITELINE_DEBUG=false

# S3 bucket receiving Fastly logs
LOG_BUCKET_NAME=siteline-fastly-logs
S3_BUCKET_REGION=us-east-1

# Lambda processor
LAMBDA_FUNCTION_NAME=siteline-fastly-s3-processor
LAMBDA_ROLE_NAME=siteline-fastly-s3-processor-role
LAMBDA_RUNTIME=nodejs20.x
LAMBDA_ARCHITECTURE=x86_64
LAMBDA_TIMEOUT_SECONDS=60
LAMBDA_MEMORY_MB=256
LAMBDA_ZIP_PATH=dist/lambda-edge.zip

# EventBridge
EVENT_RULE_NAME=siteline-fastly-s3-log-created
EVENT_TARGET_ID=siteline-lambda-target

# Fastly API + logging endpoint setup
FASTLY_API_TOKEN=fastly_api_token_here
FASTLY_SERVICE_ID=fastly_service_id_here
# Optional: set to update this version directly; otherwise script uses active version and clones if needed
FASTLY_SERVICE_VERSION=
FASTLY_LOG_ENDPOINT_NAME=siteline-fastly-s3
FASTLY_S3_ACCESS_KEY=aws_access_key_for_fastly
FASTLY_S3_SECRET_KEY=aws_secret_key_for_fastly
FASTLY_S3_PATH=fastly/%Y/%m/%d/%H/%M/%S.log.gz
FASTLY_LOG_COMPRESSION_CODEC=gzip
FASTLY_LOG_UPLOAD_PERIOD_SECONDS=60
FASTLY_SKIP_ACTIVATE=false
